{
  "name": "note2video-editor",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone Electron studio UI for Note2Video projects (preview + timeline; does not replace the CLI/Qt pipeline).",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitecut/timeline": "^0.0.4",
    "fabric": "^6.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavesurfer.js": "^7.9.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "wait-on": "^8.0.1"
  }
}
